# Common environment variables
LOG_LEVEL=INFO

# Required object storage settings (fail fast when missing)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=local-access-key
OBJECT_STORE_SECRET_KEY=local-secret-key
OBJECT_STORE_BUCKET=rag-artifacts
OBJECT_STORE_USE_SSL=false

# Optional overrides
INGESTION_DB_PATH=data/ingestion_jobs.db
PROCESSING_DB_PATH=data/processing_jobs.db
TESTSET_DB_PATH=data/testset_jobs.db
PROCESSING_EMBEDDING_MAX_BATCH_SIZE=512
# Per-service override example (compose SERVICE_NAME maps to Settings.service_name)
# Prefix environment variables with the uppercased service name to override shared values per service.
# Example for ingestion-service:
# INGESTION_SERVICE_OBJECT_STORE_BUCKET=ingestion-unique-bucket
